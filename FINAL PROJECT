"""
Snakes and Ladders - Terminal-Based Game
CMPSC 132 Final Project

A 2 to 4 player Snakes and Ladders game played in the terminal.
Players roll a dice each turn and move along a 100-cell board.
Landing on a snake head slides the player down; landing on a ladder
bottom climbs the player up. The first player to land exactly on
cell 100 wins.
"""

import random
import sys
import termios

# Snake mappings: head cell -> tail cell (sliding down)
SNAKES = {16: 6, 48: 30, 64: 60, 79: 19, 93: 68, 99: 22}

# Ladder mappings: bottom cell -> top cell (climbing up)
LADDERS = {4: 14, 9: 31, 20: 38, 28: 84, 40: 59, 51: 67, 71: 92}


class SnakesAndLadders:
    """
    Represents a full game of Snakes and Ladders.

    Supports 2 to 4 players. Uses dictionaries to store snake and
    ladder positions, and tracks each player's position and stats
    throughout the game.

    Attributes:
        snakes (dict): Maps snake head positions to tail positions.
        ladders (dict): Maps ladder bottom positions to top positions.
    """

    def __init__(self):
        """Initialize the game with snake and ladder position mappings."""
        self.snakes = SNAKES
        self.ladders = LADDERS

    def _get_player_count(self):
        """
        Prompt the user to enter the number of players and validate the input.

        Keeps asking until a valid integer between 2 and 4 is entered.

        Returns:
            int: Number of players (2, 3, or 4).
        """
        while True:
            try:
                n = int(input("How many players? (2-4): "))
                if 2 <= n <= 4:
                    return n
                print("Please enter 2, 3, or 4.")
            except ValueError:
                print("Invalid input. Enter a whole number.")

    def _get_player_names(self, n):
        """
        Collect a name for each player from user input.

        If a player leaves their name blank, it defaults to 'Player N'.

        Args:
            n (int): Number of players.

        Returns:
            list: A list of player name strings.
        """
        players = []
        for i in range(n):
            name = input(f"Enter name for Player {i + 1}: ").strip()
            if not name:
                name = f"Player {i + 1}"
            players.append(name)
        return players

    def roll_dice(self):
        """
        Simulate a single six-sided dice roll.

        Returns:
            int: A random number between 1 and 6 (inclusive).
        """
        return random.randint(1, 6)

    def print_board(self, positions):
        """
        Display the current state of the 10x10 game board in the terminal.

        Each cell shows its number along with a marker:
            S = snake head (player slides down)
            L = ladder bottom (player climbs up)
            1-4 = current position of each player

        The board follows the standard Snakes and Ladders layout where
        even rows go left to right and odd rows go right to left.

        Args:
            positions (dict): Maps player names to their current cell numbers.
        """
        # Build a marker map: cell number -> display character
        markers = {}
        for head in self.snakes:
            markers[head] = 'S'
        for bottom in self.ladders:
            markers[bottom] = 'L'

        # Player numbers override snake/ladder markers on the same cell
        for i, (player, pos) in enumerate(positions.items()):
            if pos > 0:
                markers[pos] = str(i + 1)

        divider = "+-------" * 10 + "+"
        print("\n" + divider)

        # Print rows from top (row 9) down to bottom (row 0)
        for r in range(9, -1, -1):
            row_str = "|"
            for col in range(10):
                # Even rows go left to right, odd rows go right to left
                if r % 2 == 0:
                    cell = r * 10 + col + 1
                else:
                    cell = r * 10 + (10 - col)
                m = markers.get(cell, ' ')
                row_str += f"  {m}{cell:3} |"
            print(row_str)
            print(divider)

        print("  S=Snake head  L=Ladder bottom  1-4=Player positions\n")

    def move_player(self, player, pos, roll, stats):
        """
        Move a player forward by the rolled amount and apply any snake or
        ladder effects at the new position.

        If the roll would move the player past cell 100, they stay in place
        (overshoot rule). If they land exactly on 100, they win. If they
        land on a snake head, they slide to the snake's tail. If they land
        on a ladder bottom, they climb to the ladder's top.

        Args:
            player (str): The name of the player being moved.
            pos (int): The player's current position before rolling.
            roll (int): The dice roll value.
            stats (dict): Tracks each player's snakes hit and ladders climbed.

        Returns:
            int: The player's updated position after moving and any effects.
        """
        new_pos = pos + roll

        # Overshoot rule: player must land exactly on 100 to win
        if new_pos > 100:
            print(f"  Needs {100 - pos} to win but rolled {roll}. Stays at {pos}.")
            return pos

        print(f"  Moves {pos} → {new_pos}.", end=" ")

        # Check for winning move
        if new_pos == 100:
            print()
            return new_pos

        # Check if player landed on a snake head
        if new_pos in self.snakes:
            tail = self.snakes[new_pos]
            print(f"SNAKE at {new_pos}! Slides down to {tail}.")
            stats[player]['snakes_hit'] += 1
            return tail

        # Check if player landed on a ladder bottom
        if new_pos in self.ladders:
            top = self.ladders[new_pos]
            print(f"LADDER at {new_pos}! Climbs up to {top}.")
            stats[player]['ladders_climbed'] += 1
            return top

        print()
        return new_pos

    def display_stats(self, players, stats, winner):
        """
        Print an end-of-game statistics summary for all players.

        Shows each player's total dice rolls, number of snakes hit,
        and number of ladders climbed. Also announces the winner and
        how many rolls it took them to win.

        Args:
            players (list): List of player name strings.
            stats (dict): Each player's rolls, snakes_hit, and ladders_climbed.
            winner (str): The name of the winning player.
        """
        print("\n" + "=" * 43)
        print("            GAME STATISTICS")
        print("=" * 43)
        for player in players:
            s = stats[player]
            print(f"\n{player}:")
            print(f"  Total rolls:      {s['rolls']}")
            print(f"  Snakes hit:       {s['snakes_hit']}")
            print(f"  Ladders climbed:  {s['ladders_climbed']}")
        print(f"\n  {winner} won in {stats[winner]['rolls']} rolls!\n")

    def play(self):
        """
        Run the main game loop.

        Sets up players, alternates turns, updates positions, and checks
        for a winner after each move. Displays the board after every turn.
        After a game ends, prompts players to play again. Supports multiple
        rounds without restarting the program.
        """
        while True:
            # Clear any buffered keystrokes left over from the previous game
            termios.tcflush(sys.stdin, termios.TCIFLUSH)

            print("\n" + "=" * 43)
            print("         SNAKES AND LADDERS")
            print("=" * 43 + "\n")

            # Set up players and tracking dictionaries
            n = self._get_player_count()
            players = self._get_player_names(n)
            positions = {p: 0 for p in players}
            stats = {
                p: {'rolls': 0, 'snakes_hit': 0, 'ladders_climbed': 0}
                for p in players
            }

            self.print_board(positions)

            current = 0  # index of the current player in the players list
            winner = None

            # Keep taking turns until someone reaches exactly 100
            while not winner:
                player = players[current]
                input(f"{player}'s turn (position: {positions[player]}). Press Enter to roll...")

                roll = self.roll_dice()
                stats[player]['rolls'] += 1
                print(f"  Rolled: {roll}")

                positions[player] = self.move_player(
                    player, positions[player], roll, stats
                )

                # Check if this player has won
                if positions[player] == 100:
                    winner = player
                else:
                    self.print_board(positions)

                # Move to the next player
                current = (current + 1) % n

            print("\n" + "=" * 43)
            print(f"  {winner} WINS THE GAME!")
            print("=" * 43)
            self.print_board(positions)
            self.display_stats(players, stats, winner)

            # Ask if players want to play another round
            again = input("Play again? (yes/no): ").strip().lower()
            if again not in ('yes', 'y'):
                print("Thanks for playing!")
                break


if __name__ == "__main__":
    game = SnakesAndLadders()
    game.play()
